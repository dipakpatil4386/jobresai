SECRET_KEY=change-me-in-production

# Vercel sets VERCEL=1 automatically. On Vercel, WebSocket is off and upload limit defaults to 4MB.
# WEBSOCKET_ENABLED=false
# MAX_UPLOAD_MB=4

# AI resume coach — OpenRouter (https://openrouter.ai) or OpenAI-compatible API
AI_PROVIDER=openrouter
AI_RECOMMENDATIONS_ENABLED=true
AI_API_KEY=your-openrouter-api-key
AI_API_URL=https://openrouter.ai/api/v1/chat/completions
AI_MODEL=openai/gpt-4o-mini
AI_HTTP_REFERER=https://your-domain.vercel.app
AI_APP_TITLE=JobRes.ai

# Cover letter AI enhancement (uses same AI_API_KEY)
COVER_LETTER_AI_ENABLED=false

# Arbeitnow free job API — https://www.arbeitnow.com/api/job-board-api
ARBEITNOW_ENABLED=true
ARBEITNOW_API_URL=https://www.arbeitnow.com/api/job-board-api
ARBEITNOW_MAX_PAGES=1

REMOTIVE_ENABLED=true
REMOTIVE_API_URL=https://remotive.com/api/remote-jobs

REMOTEJOBS_ORG_ENABLED=true
REMOTEJOBS_ORG_API_URL=https://remotejobs.org/api/v1/jobs

# Optional paid feeds (Indeed via RapidAPI / LinkedIn)
JOB_FEEDS_ENABLED=false
INDEED_API_KEY=
INDEED_API_URL=https://indeed12.p.rapidapi.com/jobs/search
INDEED_API_HOST=indeed12.p.rapidapi.com
LINKEDIN_API_KEY=
LINKEDIN_API_URL=https://api.linkedin.com/v2/jobSearch
